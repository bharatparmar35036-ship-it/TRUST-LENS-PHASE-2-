# =====================================================
# TRUSTLENS – HYBRID ENGINE CONFIGURATION
# =====================================================

# ---------------- SERVER ----------------
NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=info

# ---------------- BACKEND URL ----------------
BACKEND_BASE_URL=http://localhost:3000

# ---------------- SECURITY ----------------
MAX_TEXT_LENGTH=2000
MIN_TEXT_LENGTH=15
REQUEST_TIMEOUT=10000
ENABLE_STRICT_VALIDATION=true

# ---------------- RATE LIMIT ----------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ---------------- CACHE ----------------
CACHE_TTL=3600

# ---------------- HYBRID ENGINE WEIGHTS ----------------
# MUST sum to 1.0
WEIGHT_RULE_ENGINE=0.55
WEIGHT_AI_ENGINE=0.45

# ---------------- AI (Gemini) ----------------
ENABLE_GEMINI=true
GEMINI_API_KEY=key-1234567890abcdef
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT=8000

# ---------------- GOOGLE FACT CHECK ----------------
ENABLE_GOOGLE_FACT_CHECK=true
GOOGLE_FACT_CHECK_API_KEY=key-1234567890abcdef
GOOGLE_FACT_CHECK_TIMEOUT=5000

# ---------------- RULE ENGINE SOURCE WEIGHTS ----------------
# Used internally in rule engine
WEIGHT_GOOGLE_FACT_CHECK=0.45
WEIGHT_WIKIPEDIA=0.35
WEIGHT_IFCN=0.20

# ---------------- RISK CLASSIFICATION ----------------
CONFIDENCE_RELIABLE=80
CONFIDENCE_QUESTIONABLE=60
CONFIDENCE_MISLEADING=40
CONFIDENCE_HIGH_RISK=0

# ---------------- FEATURE FLAGS ----------------
ENABLE_EXPLAINABILITY=true
ENABLE_DOMAIN_SCORING=true
ENABLE_PARALLEL_PROCESSING=true
ENABLE_FAILSAFE_MODE=true
ENABLE_EXPLANATION=true
EXPLANATION_TIMEOUT_MS=10000
